---
interface Props {
  url: string
  title?: string
  width?: string
  aspectRatio?: string
  allowFullscreen?: boolean
}

const {
  url,
  title = 'Figma design',
  width = '100%',
  aspectRatio = '16/9',
  allowFullscreen = true
} = Astro.props

/**
 * Figma supports two iframe patterns:
 *   - figma.site (Figma Sites — published pages): embed the URL directly.
 *   - figma.com (design files / FigJam / prototypes): wrap in /embed?url=…
 *
 * The /embed wrapper rejects figma.site URLs with "Invalid URL", so we sniff
 * the host first and only wrap when needed. (kellyny-land-v3 KLY-51 fix.)
 */
const isFigmaSite = /(^|\.)figma\.site$/i.test(new URL(url).hostname)
const embedUrl = isFigmaSite
  ? url
  : `https://www.figma.com/embed?embed_host=astro&url=${encodeURIComponent(url)}`
---

<div class="embed-container" style={`width: ${width}; aspect-ratio: ${aspectRatio};`}>
  <iframe
    src={embedUrl}
    title={title}
    loading="lazy"
    allowfullscreen={allowFullscreen}
    allow="fullscreen"
  ></iframe>
</div>
<p class="embed-fallback">
  <a href={url} target="_blank" rel="noopener noreferrer">Open in Figma</a>
</p>

<style>
  .embed-container {
    position: relative;
    max-width: 100%;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .embed-container iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .embed-fallback {
    font-size: var(--text-sm);
    color: var(--color-ink);
    margin-top: var(--space-2);
  }

  @media print {
    .embed-container iframe { display: none; }
    .embed-fallback { display: block; }
  }
</style>
