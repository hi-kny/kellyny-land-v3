---
interface Props {
  presentationId: string
  width?: string
  aspectRatio?: string
  startSlide?: number
  autoplay?: boolean
  loop?: boolean
}

const {
  presentationId,
  width = '100%',
  aspectRatio = '16/9',
  startSlide = 1,
  autoplay = false,
  loop = false
} = Astro.props

const embedUrl = `https://docs.google.com/presentation/d/${presentationId}/embed?start=${autoplay}&loop=${loop}&delayms=3000&slide=${startSlide}`
const directUrl = `https://docs.google.com/presentation/d/${presentationId}`
---

<div class="embed-container" style={`width: ${width}; aspect-ratio: ${aspectRatio};`}>
  <iframe
    src={embedUrl}
    title="Google Slides presentation"
    loading="lazy"
    allowfullscreen
    sandbox="allow-scripts allow-same-origin allow-popups"
  ></iframe>
  <noscript>
    <a href={directUrl} target="_blank" rel="noopener noreferrer">View presentation on Google Slides</a>
  </noscript>
</div>

<style>
  .embed-container {
    position: relative;
    max-width: 100%;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .embed-container iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media print {
    .embed-container iframe { display: none; }
    .embed-container::after {
      content: 'Google Slides presentation (see online version)';
      color: var(--color-muted);
      font-size: var(--text-sm);
    }
  }
</style>
