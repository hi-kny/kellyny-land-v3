---
interface Section {
  id: string;
  label: string;
}

interface Props {
  sections: Section[];
  label?: string;
}

const { sections, label = 'On this page' } = Astro.props;
---

<aside class="toc" aria-label={label}>
  <details class="toc__mobile">
    <summary>
      <span class="toc__mobile-label">{label}</span>
      <span class="toc__mobile-chevron" aria-hidden="true">▾</span>
    </summary>
    <nav>
      <ul>
        {sections.map((s) => (
          <li>
            <a href={`#${s.id}`} data-toc-link={s.id}>{s.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </details>

  <nav class="toc__desktop" aria-label={label}>
    <p class="toc__heading">{label}</p>
    <ul>
      {sections.map((s) => (
        <li>
          <a href={`#${s.id}`} data-toc-link={s.id}>{s.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<script>
  // Scroll-spy — mark the currently visible section as active.
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (links.length) {
    const byId = new Map<string, HTMLAnchorElement[]>();
    links.forEach((link) => {
      const id = link.dataset.tocLink;
      if (!id) return;
      const arr = byId.get(id) ?? [];
      arr.push(link);
      byId.set(id, arr);
    });

    const setActive = (id: string) => {
      byId.forEach((arr, k) => {
        arr.forEach((a) => {
          if (k === id) a.setAttribute('aria-current', 'location');
          else a.removeAttribute('aria-current');
        });
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        // Pick the topmost intersecting entry.
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible.length && visible[0].target.id) {
          setActive(visible[0].target.id);
        }
      },
      {
        rootMargin: '-88px 0px -66% 0px',
        threshold: 0,
      },
    );

    byId.forEach((_, id) => {
      const section = document.getElementById(id);
      if (section) observer.observe(section);
    });
  }
</script>

<style>
  .toc {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  /* Mobile dropdown */
  .toc__mobile {
    display: block;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    position: sticky;
    top: calc(var(--nav-height) + var(--space-4));
    z-index: 10;
  }
  .toc__mobile summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    cursor: pointer;
    list-style: none;
    font-weight: 600;
  }
  .toc__mobile summary::-webkit-details-marker {
    display: none;
  }
  .toc__mobile-chevron {
    transition: transform var(--motion-fast) var(--ease-out);
    font-size: var(--text-base);
  }
  .toc__mobile[open] .toc__mobile-chevron {
    transform: rotate(180deg);
  }
  .toc__mobile ul {
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .toc__mobile a {
    display: block;
    padding: var(--space-2);
    color: var(--color-ink);
    text-decoration: none;
    border-radius: var(--radius-sm);
  }
  .toc__mobile a:hover,
  .toc__mobile a[aria-current='location'] {
    background: var(--color-canvas);
    color: var(--color-orange-text);
  }

  .toc__desktop {
    display: none;
  }

  .toc__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin-bottom: var(--space-3);
  }

  @media (min-width: 1024px) {
    .toc__mobile {
      display: none;
    }
    .toc__desktop {
      display: block;
      position: sticky;
      top: calc(var(--nav-height) + var(--space-6));
    }
    .toc__desktop ul {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      border-left: 1px solid var(--color-rule);
    }
    .toc__desktop a {
      display: block;
      padding: var(--space-2) var(--space-4);
      margin-left: -1px;
      color: var(--color-ink);
      text-decoration: none;
      border-left: 2px solid transparent;
      transition:
        color var(--motion-fast) var(--ease-out),
        border-color var(--motion-fast) var(--ease-out);
    }
    .toc__desktop a:hover {
      color: var(--color-orange-text);
    }
    .toc__desktop a[aria-current='location'] {
      color: var(--color-orange-text);
      border-left-color: var(--color-orange);
      font-weight: 600;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .toc__mobile-chevron,
    .toc__desktop a {
      transition: none;
    }
  }
</style>
