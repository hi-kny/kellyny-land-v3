---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  id: string;
  as?: 'section' | 'div' | 'article';
}

const { id, as: Tag = 'section', class: className = '', ...rest } = Astro.props;
const classList = ['anchor-section', className].filter(Boolean).join(' ');
---

<Tag id={id} class={classList} {...rest}>
  <slot />
</Tag>

<style>
  .anchor-section {
    scroll-margin-top: var(--nav-height, 88px);
  }
</style>
