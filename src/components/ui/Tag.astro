---
import type { HTMLAttributes } from 'astro/types';

type TagColor = 'orange' | 'blue' | 'green' | 'muted';

interface Props extends HTMLAttributes<'span'> {
  color?: TagColor;
  interactive?: boolean;
}

const { color = 'orange', interactive = false, class: className = '', ...rest } = Astro.props;
const classList = ['tag', `tag--${color}`, interactive && 'tag--interactive', className]
  .filter(Boolean)
  .join(' ');
---

<span class={classList} {...rest}>
  <slot />
</span>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-xs);
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    background: transparent;
    border: 1px solid currentColor;
    white-space: nowrap;
  }

  .tag--orange { color: var(--color-orange-text); }
  .tag--blue   { color: var(--color-blue); }
  .tag--green  { color: var(--color-green); }
  .tag--muted  { color: var(--color-muted); }

  .tag--interactive {
    cursor: pointer;
    transition:
      background-color var(--motion-fast) var(--ease-out),
      color var(--motion-fast) var(--ease-out);
  }
  .tag--interactive:hover {
    background: currentColor;
  }
  .tag--interactive:hover > * {
    color: var(--color-canvas);
  }
</style>
