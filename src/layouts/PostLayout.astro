---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/patterns/Nav.astro';
import Footer from '../components/patterns/Footer.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import MetaRow from '../components/ui/MetaRow.astro';
import Button from '../components/ui/Button.astro';

interface Props {
  title: string;
  description?: string;
  pubDate?: Date | string;
  category?: string;
  readingTime?: string | number;
  image?: string;
  ogImage?: string;
}

const {
  title,
  description,
  pubDate,
  category,
  readingTime,
  image,
  ogImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, 'https://kellyny.land').toString();
const tweetText = `${title} — by Kelly Nyland`;
const twitterIntent = `https://twitter.com/intent/tweet?text=${encodeURIComponent(tweetText)}&url=${encodeURIComponent(canonical)}`;
---

<BaseLayout title={`${title} — Kelly Nyland`} description={description} ogImage={ogImage ?? image} ogType="article">
  <Nav slot="nav" />
  <article class="post">
    <header class="post__head">
      {category && <Eyebrow>{category}</Eyebrow>}
      <h1 class="post__title">{title}</h1>
      {(pubDate || readingTime || category) && (
        <div class="post__meta">
          <MetaRow date={pubDate} readingTime={readingTime} category={category} />
        </div>
      )}
      {image && (
        <div class="post__cover">
          <img src={image} alt={`${title} cover`} loading="eager" decoding="async" />
        </div>
      )}
    </header>

    {/* Coined-vocabulary convention (PLAN §3.2): authors italicize a coined term
        in MDX with `*Selfware*` or `_Selfware_`. Global `.prose em` styling
        below picks up the Lora-italic + Orange treatment automatically. */}
    <div class="prose">
      <slot />
    </div>

    <footer class="post__foot">
      <div class="post__share">
        <span class="post__share-label">Share:</span>
        <a class="post__share-link" href={twitterIntent} target="_blank" rel="noopener noreferrer">
          Twitter / X
        </a>
        <button type="button" class="post__share-link" data-copy-link={canonical}>
          Copy link
        </button>
      </div>
      <Button href="https://substack.com/@motherofdata" variant="ghost" size="md">
        Subscribe on Substack →
      </Button>
    </footer>
  </article>
  <Footer slot="footer" />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('button[data-copy-link]');
  buttons.forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.copyLink ?? window.location.href;
      try {
        await navigator.clipboard.writeText(url);
        const original = btn.textContent;
        btn.textContent = 'Copied ✓';
        setTimeout(() => { btn.textContent = original; }, 1500);
      } catch {
        // Clipboard blocked; do nothing.
      }
    });
  });
</script>

<style>
  .post {
    max-width: var(--width-prose);
    margin-inline: auto;
    padding-inline: var(--space-6);
    padding-block: var(--space-12);
  }
  @media (min-width: 768px) {
    .post {
      padding-block: var(--space-16);
    }
  }

  .post__head {
    margin-bottom: var(--space-8);
  }
  .post__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin-bottom: var(--space-4);
  }
  @media (min-width: 768px) {
    .post__title {
      font-size: var(--text-5xl);
    }
  }
  .post__meta {
    margin-bottom: var(--space-6);
  }
  .post__cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--color-surface);
  }
  .post__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Body prose */
  .prose {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-body);
    color: var(--color-ink);
  }
  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol),
  .prose :global(blockquote),
  .prose :global(figure) {
    margin-block: var(--space-4);
  }
  .prose :global(p:first-child) {
    margin-top: 0;
  }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-2xl);
    color: var(--color-ink);
    margin-top: var(--space-12);
    margin-bottom: var(--space-3);
    line-height: var(--leading-snug);
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin-top: var(--space-8);
    margin-bottom: var(--space-2);
    line-height: var(--leading-snug);
  }
  .prose :global(a) {
    color: var(--color-orange-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .prose :global(a:hover) {
    text-decoration-thickness: 2px;
  }
  /* Coined-vocabulary treatment per PLAN §3.2 — Lora italic with Orange
     1px underline picked up on hover. */
  .prose :global(em) {
    font-style: italic;
    color: var(--color-orange-text);
    border-bottom: 1px solid transparent;
    transition: border-color var(--motion-fast) var(--ease-out);
  }
  .prose :global(em:hover) {
    border-bottom-color: var(--color-orange-text);
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-orange);
    padding-left: var(--space-6);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--color-ink);
  }
  .prose :global(ul) {
    padding-left: var(--space-6);
  }
  .prose :global(li) {
    list-style: disc;
    margin-left: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .prose :global(img) {
    width: 100%;
    border-radius: var(--radius-md);
    margin-block: var(--space-6);
  }
  .prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.94em;
    background: var(--color-surface);
    padding: 0.15em 0.35em;
    border-radius: var(--radius-sm);
  }

  .post__foot {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-rule);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .post__share {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .post__share-label {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--color-ink);
  }
  .post__share-link {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--color-orange-text);
    background: none;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
    cursor: pointer;
    text-decoration: none;
    transition: border-color var(--motion-fast) var(--ease-out);
  }
  .post__share-link:hover {
    border-color: var(--color-orange-text);
  }

  @media (prefers-reduced-motion: reduce) {
    .prose :global(em),
    .post__share-link {
      transition: none;
    }
  }
</style>
