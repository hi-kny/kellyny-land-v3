---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/patterns/Nav.astro';
import Footer from '../components/patterns/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout
  title="Page not found — Kelly Nyland"
  description="The page you were looking for isn't here."
>
  <Nav slot="nav" />
  <Section variant="narrow" padded>
    <div class="not-found">
      <p class="not-found__code">404</p>
      <h1 class="not-found__title">This page isn't here.</h1>
      <p class="not-found__body">
        The link may be stale, or I may have moved things around. Head back home and try again.
      </p>
      <Button href="/" variant="primary" size="lg">← Back to home</Button>
    </div>
  </Section>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding-block: var(--space-16);
  }
  .not-found__code {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin-bottom: var(--space-4);
  }
  .not-found__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-4xl);
    color: var(--color-ink);
    margin-bottom: var(--space-4);
  }
  .not-found__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-body);
    color: var(--color-ink);
    max-width: 32rem;
    margin: 0 auto var(--space-8);
  }
</style>
