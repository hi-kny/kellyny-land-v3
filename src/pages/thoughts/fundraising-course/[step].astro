---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/patterns/Nav.astro';
import Footer from '../../../components/patterns/Footer.astro';
import Section from '../../../components/ui/Section.astro';
import Eyebrow from '../../../components/ui/Eyebrow.astro';
import Button from '../../../components/ui/Button.astro';
import YouTubeEmbed from '../../../components/embeds/YouTubeEmbed.astro';
import { fundraisingLessons } from '../../../data/mediaEmbeds.ts';

export function getStaticPaths() {
  return fundraisingLessons.map((lesson, index) => ({
    params: { step: `step-${index}` },
    props: { lesson, index, total: fundraisingLessons.length },
  }));
}

const { lesson, index, total } = Astro.props;
const prev = index > 0 ? index - 1 : null;
const next = index < total - 1 ? index + 1 : null;
const prevLesson = prev !== null ? fundraisingLessons[prev] : null;
const nextLesson = next !== null ? fundraisingLessons[next] : null;
---

<BaseLayout
  title={`${lesson.shortTitle} — Fundraising Course — Kelly Nyland`}
  description={lesson.description}
  ogType="article"
>
  <Nav slot="nav" />
  <Section variant="content" padded>
    <header class="step-hero">
      <Eyebrow>
        Step {index} of {total - 1} <span aria-hidden="true">·</span> {lesson.duration}
      </Eyebrow>
      <h1 class="step-hero__title">
        <span class="step-hero__emoji" aria-hidden="true">{lesson.emoji}</span>
        {lesson.shortTitle}
      </h1>
      <p class="step-hero__lead">{lesson.description}</p>
    </header>

    <div class="step-video">
      <YouTubeEmbed videoId={lesson.videoId} title={`${lesson.shortTitle} — Fundraising Course`} />
    </div>

    {lesson.topics && lesson.topics.length > 0 && (
      <section class="step-topics">
        <Eyebrow>What's covered</Eyebrow>
        <ul>
          {lesson.topics.map((topic) => <li>{topic}</li>)}
        </ul>
      </section>
    )}

    <nav class="step-nav" aria-label="Course navigation">
      {prevLesson && (
        <a href={`/thoughts/fundraising-course/step-${prev}`} class="step-nav__link step-nav__link--prev">
          <span class="step-nav__direction">← Previous</span>
          <span class="step-nav__title">{prevLesson.shortTitle}</span>
        </a>
      )}
      <a href="/thoughts/fundraising-course" class="step-nav__index">All lessons</a>
      {nextLesson && (
        <a href={`/thoughts/fundraising-course/step-${next}`} class="step-nav__link step-nav__link--next">
          <span class="step-nav__direction">Next →</span>
          <span class="step-nav__title">{nextLesson.shortTitle}</span>
        </a>
      )}
    </nav>

    <section class="step-cta">
      <p class="step-cta__copy">Want help running your raise?</p>
      <Button href="/hire#hire-me" variant="primary" size="md">Book a call →</Button>
    </section>
  </Section>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .step-hero {
    margin-bottom: var(--space-8);
  }
  .step-hero__title {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin-bottom: var(--space-4);
  }
  .step-hero__emoji {
    font-size: var(--text-3xl);
  }
  .step-hero__lead {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-body);
    color: var(--color-ink);
    max-width: var(--width-prose);
  }

  .step-video {
    margin-bottom: var(--space-12);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  /* Cancel YouTubeEmbed's vertical margin when wrapped in .step-video so
     the iframe sits flush against the rounded container. */
  .step-video :global(.embed-container) {
    margin-block: 0;
    border-radius: 0;
  }

  .step-topics {
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-rule);
    margin-bottom: var(--space-8);
  }
  .step-topics ul {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-body);
    color: var(--color-ink);
    max-width: var(--width-prose);
    padding-left: var(--space-6);
  }
  .step-topics li {
    list-style: disc;
    margin-left: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .step-nav {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding-block: var(--space-12);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    margin-bottom: var(--space-12);
  }
  @media (min-width: 768px) {
    .step-nav {
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
    }
  }
  .step-nav__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    color: var(--color-ink);
    text-decoration: none;
    padding: var(--space-3) 0;
  }
  .step-nav__link:hover {
    color: var(--color-orange-text);
  }
  .step-nav__link--next {
    text-align: right;
  }
  .step-nav__direction {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-orange-text);
  }
  .step-nav__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-lg);
  }
  .step-nav__index {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--color-ink);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-align: center;
    padding: var(--space-3);
  }

  .step-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    padding-block: var(--space-8);
  }
  .step-cta__copy {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    color: var(--color-ink);
  }
</style>
